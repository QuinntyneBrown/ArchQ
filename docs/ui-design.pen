                  "layout": "vertical",
                  "gap": 16,
                  "padding": 24,
                  "children": [
                    {
                      "type": "text",
                      "id": "ZmtXj",
                      "name": "mdH2",
                      "fill": "$text-primary",
                      "content": "Context",
                      "fontFamily": "Inter",
                      "fontSize": "$font-xl",
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "ItvKa",
                      "name": "mdP1",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Our application currently uses a mix of SQLite for development and MySQL for production. This inconsistency has led to several issues including migration failures, inconsistent query behavior, and difficulty onboarding new developers. We need a unified database strategy that works across all environments.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": "$font-sm",
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "BzbcU",
                      "name": "mdH2b",
                      "fill": "$text-primary",
                      "content": "Decision",
                      "fontFamily": "Inter",
                      "fontSize": "$font-xl",
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "mIzCG",
                      "name": "mdP2",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We will adopt PostgreSQL as the primary database for all environments. PostgreSQL provides advanced features like JSONB columns, full-text search, and robust transaction support. Docker Compose will be used to ensure consistent database environments across development, staging, and production.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": "$font-sm",
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "KUcNF",
                      "name": "mdH2c",
                      "fill": "$text-primary",
                      "content": "Consequences",
                      "fontFamily": "Inter",
                      "fontSize": "$font-xl",
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "XFaCz",
                      "name": "mdP3",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Positive: Unified database across all environments, advanced querying capabilities, strong community support, and excellent tooling ecosystem.\n\nNegative: Team needs PostgreSQL training, migration effort from existing MySQL data, slightly higher memory footprint compared to SQLite for development.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": "$font-sm",
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
