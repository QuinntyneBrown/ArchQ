@startuml c4_component
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Component Diagram — General Notes (Feature 14)

Container_Boundary(api, "ArchQ API") {
    Component(ctrl, "NoteController", "REST Controller", "CRUD endpoints for /api/adrs/{id}/notes")
    Component(svc, "NoteService", "Service", "Validates fields, checks ADR status, enforces ownership, orchestrates CRUD")
    Component(noteRepo, "NoteRepository", "Repository", "CRUD for notes collection")
    Component(adrRepo, "AdrRepository", "Repository", "Loads ADR to verify status is Draft or InReview")
    Component(auditRepo, "AuditRepository", "Repository", "Records note creation/update/deletion in audit trail")
    Component(tenantCtx, "TenantContext", "Middleware", "Extracts tenant slug from JWT")
}

ContainerDb(cb, "Couchbase", "archq bucket", "Scopes: {tenant_slug}. Collections: notes, adrs, audit")

Rel(ctrl, svc, "Delegates CRUD operations")
Rel(svc, adrRepo, "Loads ADR for status check")
Rel(svc, noteRepo, "Creates / reads / updates / deletes notes")
Rel(svc, auditRepo, "Writes audit entries")
Rel(noteRepo, cb, "N1QL / KV ops on notes")
Rel(adrRepo, cb, "KV GET on adrs")
Rel(auditRepo, cb, "KV INSERT on audit")
Rel(ctrl, tenantCtx, "Reads tenant scope")

@enduml
