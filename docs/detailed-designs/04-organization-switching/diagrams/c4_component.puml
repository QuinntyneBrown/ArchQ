@startuml c4_component
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title C4 Component Diagram — Organization Switching

System_Boundary(frontend, "Web Application (SPA)") {
    Component(switcher, "OrgSwitcherComponent", "UI Component", "Sidebar dropdown showing org memberships;\nhandles org selection and triggers switch")
    Component(store, "AuthStore", "State Management", "Holds current user, tenant, and tokens;\nupdates on org switch")
}

Container_Boundary(api, "API Service") {
    Component(ctrl, "OrgController", "Express Router", "GET /api/orgs\nPOST /api/orgs/switch")
    Component(svc, "OrgSwitchService", "Service", "Validates membership, fetches target roles,\nrevokes old tokens, issues new tokens")
    Component(token, "TokenService", "Service", "Creates new JWT with updated tenant claims")
    Component(grepo, "GlobalUserRepository", "Repository", "Reads memberships from _system.global_users")
    Component(urepo, "UserRepository", "Repository", "Reads user roles from {target_tenant}.users")
    Component(rrepo, "RefreshTokenRepository", "Repository", "Revokes old family, stores new refresh token")
    Component(mw, "TenantContextMiddleware", "Middleware", "Reads tenant claims from JWT on each request")
    Component(audit, "AuditService", "Service", "Records ORG_SWITCHED audit events")
}

ContainerDb(cb, "Couchbase Cluster", "Couchbase 7+", "_system.global_users\n_system.refresh_tokens\n{tenant}.users")

Rel(switcher, store, "Reads memberships")
Rel(switcher, ctrl, "POST /api/orgs/switch", "HTTPS")
Rel(store, mw, "Sends JWT cookie")
Rel(ctrl, svc, "Invokes")
Rel(svc, grepo, "Validates membership")
Rel(svc, urepo, "Fetches roles in target")
Rel(svc, token, "Issues new tokens")
Rel(svc, rrepo, "Rotates refresh token")
Rel(svc, audit, "Records audit")
Rel(grepo, cb, "KV", "_system.global_users")
Rel(urepo, cb, "KV", "{tenant}.users")
Rel(rrepo, cb, "KV", "_system.refresh_tokens")

SHOW_LEGEND()
@enduml
